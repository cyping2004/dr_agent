# ===== LLM Configuration =====
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=deepseek-v3.2
# Judge model for LLM-as-judge (defaults to OPENAI_MODEL if unset)
JUDGE_MODEL=kimi-k2.5


# ===== Web Search Configuration =====
WEB_SEARCH_PROVIDER=tavily
TAVILY_API_KEY=tvly-your-tavily-api-key-here
# 使用 duckduckgo（无需 API 密钥）:
# WEB_SEARCH_PROVIDER=duckduckgo

# ===== Embedding Configuration =====
# 使用本地嵌入模型或api
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_MODEL_PATH=/home/your_user_name/.../qwen3-embedding-0.6b
EMBEDDING_DEVICE=cuda:1
EMBEDDING_LOCAL_BATCH_SIZE=64
EMBEDDING_MAX_WORKERS=4